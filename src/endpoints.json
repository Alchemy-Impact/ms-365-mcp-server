[
  {
    "pathPattern": "/me/messages",
    "method": "get",
    "toolName": "list-mail-messages",
    "scopes": ["Mail.Read"],
    "llmTip": "When searching emails, wrap $search value in double quotes. Example: $search=\"from:john@example.com\". Use $select to keep payloads small."
  },
  {
    "pathPattern": "/me/messages/{message-id}",
    "method": "get",
    "toolName": "get-mail-message",
    "scopes": ["Mail.Read"]
  },
  {
    "pathPattern": "/me/mailFolders",
    "method": "get",
    "toolName": "list-mail-folders",
    "scopes": ["Mail.Read"]
  },
  {
    "pathPattern": "/me/mailFolders/{mailFolder-id}/childFolders",
    "method": "get",
    "toolName": "list-mail-child-folders",
    "scopes": ["Mail.Read"]
  },
  {
    "pathPattern": "/me/mailFolders/{mailFolder-id}/messages",
    "method": "get",
    "toolName": "list-mail-folder-messages",
    "scopes": ["Mail.Read"],
    "llmTip": "When searching emails, wrap $search value in double quotes. Example: $search=\"subject:invoice\". Use $select to keep payloads small."
  },
  {
    "pathPattern": "/me/sendMail",
    "method": "post",
    "toolName": "send-mail",
